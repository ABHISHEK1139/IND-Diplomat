# IND-Diplomat Environment Configuration
# Copy to .env and adjust values as needed

# ── LLM Runtime ────────────────────────────────────
# Default: local Ollama for easiest first run.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434/api/generate
LLM_MODEL=deepseek-r1:8b
LAYER4_MODEL=deepseek-r1:8b
OLLAMA_FALLBACK_ONLY=true
CLOUD_LLM_MAX_TOKENS=8000
DEFAULT_OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free
OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free
OPENROUTER_API_KEY=
OPENROUTER_BACKUP_MODELS=qwen/qwen3.6-plus-preview:free,nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3-next-80b-a3b-instruct:free,nousresearch/hermes-3-llama-3.1-405b:free,google/gemma-3-27b-it:free,stepfun/step-3.5-flash:free,meta-llama/llama-3.3-70b-instruct:free
OLLAMA_FALLBACK_MODELS=deepseek-r1:14b,qwen3.5:9b,deepseek-r1:8b
LLM_REQUEST_TIMEOUT_SEC=600
OPENROUTER_FAILFAST_ON_429=true
OPENROUTER_FAILFAST_ON_NETWORK_ERROR=true
OPENROUTER_DEGRADED_TTL_SEC=1800
OPENROUTER_MODEL_MAX_TOKENS=qwen/qwen3.6-plus-preview:free=8000,nvidia/nemotron-3-super-120b-a12b:free=8000,qwen/qwen3-next-80b-a3b-instruct:free=8000,nousresearch/hermes-3-llama-3.1-405b:free=7000,google/gemma-3-27b-it:free=6000,stepfun/step-3.5-flash:free=3200,meta-llama/llama-3.3-70b-instruct:free=5000
LLM_PROMPT_CONTROL_ENABLED=true
LLM_PROMPT_CONTROL_TEXT=Put structured output first. Keep rationale concise. Do not waste tokens.
L4_CLASSIFICATION_OUTPUT_BUDGET=1200
L4_MINISTER_OUTPUT_BUDGET=3000
L4_REDTEAM_OUTPUT_BUDGET=1800
L4_SYNTHESIS_OUTPUT_BUDGET=3600

# ── Storage ────────────────────────────────────────
DATA_DIR=./data
CHROMA_DATA_DIR=./data/chroma
GLOBAL_RISK_DIR=./data/global_risk
LEGAL_MEMORY_DIR=./data/legal_memory

# ── Optional: Neo4j (set to true to enable) ───────
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Optional: Redis (set to true to enable) ───────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# ── API Security ───────────────────────────────────
# Set your own key value before production use.
API_KEY=SET_YOUR_API_KEY_HERE
IND_DIPLOMAT_API_KEY=SET_YOUR_API_KEY_HERE
AUTH_MODE=development
AUTH_STRICT_SECURITY=false
AUTH_ENABLE_DEMO_USERS=true
AUTH_DEMO_ADMIN_PASSWORD=admin123
AUTH_DEMO_ANALYST_PASSWORD=analyst123
JWT_SECRET_KEY=CHANGE_ME_STRONG_SECRET

# ── CORS ───────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

# ── Logging ────────────────────────────────────────
LOG_LEVEL=INFO

# White-box transparency (show internals even on WITHHELD)
DIPLOMAT_WHITEBOX_OUTPUT=1
LLM_TRACE_ENABLED=0
LLM_TRACE_PATH=./runtime/llm_trace.txt
LLM_TRACE_TAIL_CHARS=30000
